rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow read for everyone, write for any path (images up to 10MB).
    // Works for uploads/, team/, projects/, about/, and any future folder.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && (
                     request.resource.contentType.matches('image/.*')
                     || request.resource.contentType == null
                   );
      allow delete: if true;
    }
  }
}
