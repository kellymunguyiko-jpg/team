// ============================================
// COPY THESE INTO FIREBASE CONSOLE
// ============================================
//
// 1) Firestore:
//    Firebase Console → Firestore Database → Rules → Paste firestore block → Publish
//
// 2) Storage:
//    Firebase Console → Storage → Rules → Paste storage block → Publish
//
// 3) Enable Storage if not already:
//    Firebase Console → Storage → Get started
//
// 4) Auth (optional but recommended for admin login):
//    Authentication → Sign-in method → Email/Password → Enable
//    Then add a user under Authentication → Users
// ============================================

// ---------- FIRESTORE RULES ----------
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}

// ---------- STORAGE RULES ----------
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && (
                     request.resource.contentType.matches('image/.*')
                     || request.resource.contentType == null
                   );
      allow delete: if true;
    }
  }
}
